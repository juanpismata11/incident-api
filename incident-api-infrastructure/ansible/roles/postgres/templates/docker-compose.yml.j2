services:
  postgres:
    image: postgis/postgis:16-master
    container_name: PostgresSQL
    restart: always
    environment:
      - POSTGRES_DB={POSTGRES_DB}
      - POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
    networks:
      - {{ shared_docker_network}}
    ports:
      - 5432:5432
    volumes:
      - ./data:/var/lib/postgresql

networks:
  {{ shared_docker_network }}:
    external: true